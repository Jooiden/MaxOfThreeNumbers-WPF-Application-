<Window x:Class="MaxOfThreeNumbers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Нахождение максимального числа" Height="335" Width="655">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Программа, находящая максимальное значение среди трёх введённых целых чисел."
                   FontSize="14" 
                   FontWeight="Bold" 
                   TextAlignment="Center" 
                   Margin="10,8,10,0" 
                   VerticalAlignment="Top" Height="40" Grid.Row="1"/>

        <Label Content="Введите первое число:" VerticalAlignment="Top" Margin="10,48,0,0" Grid.Row="1" Height="26"/>
        <TextBox x:Name="FirstNumberTextBox" VerticalAlignment="Top" Margin="10,68,10,0" Grid.Row="1" Height="18"/>

        <Label Content="Введите второе число:" VerticalAlignment="Top" Margin="10,98,0,0" Grid.Row="1" Height="26"/>
        <TextBox x:Name="SecondNumberTextBox" VerticalAlignment="Top" Margin="10,118,10,0" Grid.Row="1" Height="18"/>

        <Label Content="Введите третье число:" VerticalAlignment="Top" Margin="10,148,0,0" Grid.Row="1" Height="26"/>
        <TextBox x:Name="ThirdNumberTextBox" VerticalAlignment="Top" Margin="10,168,10,0" Grid.Row="1" Height="18"/>

        <Button Content="Найти максимум" VerticalAlignment="Top" Margin="10,198,10,0" Click="FindMaxButton_Click" Grid.Row="1" Height="20"/>

        
        <Button Content="Очистить" VerticalAlignment="Top" Margin="10,274,438,0" Click="ClearFieldsButton_Click" Grid.Row="1" Height="20" RenderTransformOrigin="0.516,3"/>

        
        <Button Content="Сбросить" VerticalAlignment="Top" Margin="436,274,10,0" Click="ResetButton_Click" Grid.Row="1" Height="20"/>

        <TextBlock x:Name="ResultTextBlock" VerticalAlignment="Top" Margin="10,223,10,0" FontWeight="Bold" RenderTransformOrigin="0.651,-1.75" Grid.Row="1" Height="16"/>
    </Grid>
</Window>